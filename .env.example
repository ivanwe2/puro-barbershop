# =============================================================================
# Puro Barbershop — Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — NEVER commit it.
# All variables are validated at boot time via src/lib/env.ts (Zod).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon Postgres)
# Dev default: docker-compose Postgres
# Prod: Neon pooled (runtime) + unpooled (migrations only)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://puro:puro_dev_only@localhost:5432/puro_barbershop
DATABASE_URL_UNPOOLED=postgresql://puro:puro_dev_only@localhost:5432/puro_barbershop

# -----------------------------------------------------------------------------
# Auth.js v5
# Generate AUTH_SECRET with: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Email
# EMAIL_TRANSPORT: 'resend' in prod, 'smtp' in dev (Mailpit)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=Puro Barbershop <no-reply@purobarbershop.com>
EMAIL_REPLY_TO=[PLACEHOLDER:shop_email]
EMAIL_TRANSPORT=smtp

# Dev only — Mailpit SMTP catcher (docker-compose)
SMTP_HOST=localhost
SMTP_PORT=1025

# -----------------------------------------------------------------------------
# Rate limiting (Upstash Redis)
# Dev: leave blank to use LocalRateLimiter stub
# Prod: fill in from Upstash dashboard
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Cron jobs (Vercel Cron Jobs verify this header)
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# Dev database seed
# Required when running npm run db:seed
# Minimum 16 characters
# -----------------------------------------------------------------------------
SEED_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Public variables (safe to expose in the browser — NEXT_PUBLIC_ prefix)
# -----------------------------------------------------------------------------

# Instagram widget (LightWidget) — set after creating account
NEXT_PUBLIC_LIGHTWIDGET_ID=[PLACEHOLDER:lightwidget_id]
NEXT_PUBLIC_INSTAGRAM_URL=[PLACEHOLDER:instagram_url]

# Shop info for SEO / structured data
NEXT_PUBLIC_SHOP_NAME=Puro Barbershop
NEXT_PUBLIC_SHOP_ADDRESS=Бул. Христо Ботев 114, Plovdiv, Bulgaria
NEXT_PUBLIC_SHOP_PHONE=[PLACEHOLDER:shop_phone]
NEXT_PUBLIC_SHOP_EMAIL=[PLACEHOLDER:shop_email]

# Approximate coordinates (refine when map pin is confirmed)
NEXT_PUBLIC_SHOP_LAT=42.1354
NEXT_PUBLIC_SHOP_LNG=24.7453
